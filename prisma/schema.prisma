datasource db {
  provider = "sqlite"
  url      = "file:./data/app.db"
}

generator client {
  provider = "prisma-client-js"
}

model ApplicationDay {
  id          String   @id @default(uuid())
  date        DateTime @unique
  count       Int
  responses   Int      @default(0)
  interviews  Int      @default(0)
  createdAt   DateTime @default(now())
}