generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model DayLog {
  id         String   @id @default(uuid())
  date       DateTime @unique
  apps       Int
  replies    Int      @default(0)
  interviews Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([date])
  @@index([createdAt])
}